@page "/"
@using PuzzleGames.Frontend.Logic
@using PuzzleGames.Frontend.Models
@using System.Timers

@rendermode InteractiveServer

<h1 class="text-center mt-4 text-secondary">Takuzu Puzzle</h1>
<div class="text-center text-secondary mt-2">
    <span class=" p-2 fs-5 ">
        @TakuzuGameLogic.FormattedTime
    </span>
</div>

<table class="table-bordered w-auto mx-auto mt-4 shadow rounded position-relative" 
       style="border-collapse: collapse; border: 3px solid #6c757d;">
    @for (int rowIndex = 0; rowIndex < TakuzuGameLogic.TakuzuBoard.Count; rowIndex++)
    {
        int row = rowIndex;
        <tr>
            @for (int colIndex = 0; colIndex < TakuzuGameLogic.TakuzuBoard[rowIndex].Count; colIndex++)
            {
                int col = colIndex;
                <td class="text-center align-middle position-relative"
                    style="width: 80px; height: 80px; border: 2px solid #dee2e6; cursor: pointer; 
                        background-color: @(TakuzuGameLogic.TakuzuBoard[row][col].IsValid ? "#ffffff" : "#f8d7da");"
                    role="button"
                    @onclick="() => HandleClick(row, col)">

                    @if (TakuzuGameLogic.TakuzuBoard[row][col].Cell == TakuzuCellEnum.Water)
                    {
                        <i class="bi bi-droplet-fill text-primary" style="font-size: 3rem;"></i>
                    }
                    else if (TakuzuGameLogic.TakuzuBoard[row][col].Cell == TakuzuCellEnum.Fire)
                    {
                        <i class="bi bi-fire text-warning" style="font-size: 3rem;"></i>
                    }

                    @if (TakuzuGameLogic.TakuzuBoard[row][col].HorizontalLineValue == TakuzuLineEnum.Equal)
                    {
                        <span class="position-absolute translate-middle-y bg-white text-dark"
                              style="right: -14px; top: 50%; width: 24px; height: 24px; font-weight: bold; font-size: 0.9rem; z-index: 10;">
                            =
                        </span>
                    }
                    @if (TakuzuGameLogic.TakuzuBoard[row][col].HorizontalLineValue == TakuzuLineEnum.Different)
                    {
                        <span class="position-absolute translate-middle-y bg-white text-dark"
                              style="right: -14px; top: 50%; width: 24px; height: 24px; font-weight: bold; font-size: 0.9rem; z-index: 10;">
                            x
                        </span>
                    }

                    @if (TakuzuGameLogic.TakuzuBoard[row][col].VerticalLineValue == TakuzuLineEnum.Equal)
                    {
                        <span class="position-absolute translate-middle-x bg-white text-dark"
                              style="bottom: -14px; left: 50%; width: 24px; height: 24px; font-weight: bold; font-size: 0.9rem; z-index: 10;">
                            =
                        </span>
                    }
                    @if (TakuzuGameLogic.TakuzuBoard[row][col].VerticalLineValue == TakuzuLineEnum.Different)
                    {
                        <span class="position-absolute translate-middle-x bg-white text-dark"
                              style="bottom: -14px; left: 50%; width: 24px; height: 24px; font-weight: bold; font-size: 0.9rem; z-index: 10;">
                            x
                        </span>
                    }
                </td>
            }
        </tr>
    }
</table>
<div class="d-flex justify-content-center gap-1 mt-4">
    <button type="button" class="btn btn-secondary" @onclick="Undo" disabled="@(!TakuzuGameLogic.CanUndo)">
        <i class="bi bi-arrow-counterclockwise"></i>
    </button>
    <button type="button" class="btn btn-secondary" @onclick="Redo" disabled="@(!TakuzuGameLogic.CanRedo)">
        <i class="bi bi-arrow-clockwise"></i>
    </button>
    <button type="button" class="btn btn-secondary" @onclick="ResetClick">Reset</button>
</div>

@if (TakuzuGameLogic.IsGameOver)
{
    <FinishGame TakuzuGameLogic="TakuzuGameLogic" OnNewGameGenerated="StateHasChanged" />
}

@code
{
    private int Size = 6;
    private TakuzuGameLogic TakuzuGameLogic;
    
    protected override void OnInitialized()
    {
        TakuzuGameLogic = new TakuzuGameLogic();
        TakuzuGameLogic.GenerateNewGame(Size);
        TakuzuGameLogic.OnTimerTicked += HandleTimerTick;
    }
    
    private void HandleTimerTick()
    {
        
        _ = InvokeAsync(() =>
        {
            StateHasChanged();
        });
    }
    
    private void HandleClick(int row, int col)
    {
        TakuzuGameLogic.ChangeCellValue(row, col);
        StateHasChanged();
    }

    private void ResetClick()
    {
        TakuzuGameLogic.ResetBoard();
        StateHasChanged();
    }

    private void Undo()
    {
        TakuzuGameLogic.Undo();
        StateHasChanged();
    }
    
    private void Redo()
    {
        TakuzuGameLogic.Redo();
        StateHasChanged();
    }
}