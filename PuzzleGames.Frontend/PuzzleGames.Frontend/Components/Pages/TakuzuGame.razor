@page "/"
@using PuzzleGames.Frontend.Logic
@using PuzzleGames.Frontend.Models

@rendermode InteractiveServer

<h1 class="text-center mt-4 text-secondary">Takuzu Puzzle</h1>

<table class="table-bordered w-auto mx-auto mt-4 shadow rounded position-relative" 
       style="border-collapse: collapse; border: 3px solid #6c757d;">
    @for (int rowIndex = 0; rowIndex < TakuzuGameLogic.TakuzuBoard.Count; rowIndex++)
    {
        int r = rowIndex;
        <tr>
            @for (int colIndex = 0; colIndex < TakuzuGameLogic.TakuzuBoard[rowIndex].Count; colIndex++)
            {
                int c = colIndex;
                <td class="text-center align-middle position-relative" 
                    style="width: 80px; height: 80px; border: 2px solid #dee2e6; background-color: #ffffff;"
                    @onclick="() => HandleClick(r, c)">
                    
                    @if (TakuzuGameLogic.TakuzuBoard[rowIndex][colIndex].Cell == TakuzuEnum.Water)
                    {
                        <i class="bi bi-droplet-fill text-primary" style="font-size: 3rem;"></i>
                    }
                    else if (TakuzuGameLogic.TakuzuBoard[rowIndex][colIndex].Cell == TakuzuEnum.Fire)
                    {
                        <i class="bi bi-fire text-warning" style="font-size: 3rem;"></i>
                    }

                    @if (colIndex == 3 && rowIndex == 1 )
                    {
                        <span class="position-absolute translate-middle-y bg-white text-dark"
                              style="right: -14px; top: 50%; width: 24px; height: 24px; font-weight: bold; font-size: 0.9rem; z-index: 10;">
                            =
                        </span>
                    }

                    @if (colIndex == 2 && rowIndex == 0 )
                    {
                        <span class="position-absolute translate-middle-x bg-white text-dark"
                              style="bottom: -14px; left: 50%; width: 24px; height: 24px; font-weight: bold; font-size: 0.9rem; z-index: 10;">
                            x
                        </span>
                    }
                </td>
            }
        </tr>
    }
</table>

@code
{
    static List<List<TakuzuCell>> TakuzuBoard = new List<List<TakuzuCell>>
    {
        new List<TakuzuCell>{new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty)},
        new List<TakuzuCell>{new TakuzuCell(TakuzuEnum.Fire), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty)},
        new List<TakuzuCell>{new TakuzuCell(TakuzuEnum.Fire), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty)},
        new List<TakuzuCell>{new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty)},
        new List<TakuzuCell>{new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Water), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Water)},
        new List<TakuzuCell>{new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty), new TakuzuCell(TakuzuEnum.Empty)}
    };

    private TakuzuGameLogic TakuzuGameLogic;
    
    protected override void OnInitialized()
    {
        TakuzuGameLogic = new TakuzuGameLogic(TakuzuBoard);
    }
    
    private void HandleClick(int row, int col)
    {
        TakuzuGameLogic.ChangeCellValue(row, col);
        StateHasChanged();
    }
}